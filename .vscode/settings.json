{
  "biome.enabled": true,
  "editor.formatOnSave": true,
  "files.associations": {
    "*.vue": "vue"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[vue]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "cSpell.words": [
    "Borel",
    "Cantelli",
    "comark",
    "filtration",
    "filtrations",
    "Fira",
    "kakuritsubibun",
    "KaTeX",
    "katex",
    "Lebesgue",
    "Markov",
    "mdc",
    "Noto",
    "Ornstein",
    "PDE",
    "PDF",
    "Poisson",
    "pushforward",
    "routerMode",
    "SDE",
    "Slidev",
    "Stieltjes",
    "Uhlenbeck",
    "Wiener"
  ]
}
